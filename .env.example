# ──────────────────────────────────────────────
#  dev-cognition-system — Environment Template
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# [Required] Groq API key — get yours free at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# LLM model to use (llama-3.1-8b-instant is fast and free-tier friendly)
GROQ_MODEL=llama-3.1-8b-instant

# Groq API endpoint (no need to change unless using a proxy)
GROQ_URL=https://api.groq.com/openai/v1/chat/completions

# Minimum seconds between consecutive Groq API calls
# Free tier: ~30 req/min. Set to 6s = 10 req/min — safe with retry headroom
GROQ_MIN_INTERVAL=6

# Output directory where Obsidian vault notes are written
VAULT_PATH=./vault

# Set to 1 to skip Groq calls and use heuristic fallback instead (useful for offline testing)
MOCK_GROQ=0
